{
  "dependencies": {
    "@dfinity/utils": "^4.1.0",
    "@icp-sdk/auth": "^5.0.0",
    "@icp-sdk/canisters": "^3.5.0",
    "@icp-sdk/core": "^5.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^25.3.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "sass": "^1.97.3",
    "svelte": "^5.53.3",
    "svelte-check": "^4.4.3",
    "syncpack": "^14.0.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@11.7.0",
  "private": true,
  "scripts": {
    "build": "npm run build --workspaces",
    "build:app": "npm run build --workspace=my-canister-app",
    "build:docs": "npm run build:docs:dashboard && npm run build:docs:vite-plugin",
    "build:docs:dashboard": "npm run docs:clean --workspace=@web3nl/my-canister-dashboard && npm run docs:build --workspace=@web3nl/my-canister-dashboard",
    "build:docs:vite-plugin": "npm run docs:clean --workspace=@web3nl/vite-plugin-canister-dapp && npm run docs:build --workspace=@web3nl/vite-plugin-canister-dapp",
    "build:setup-ii": "cd test-fixtures/ii-setup && vite build",
    "changeset": "changeset",
    "check": "npm run lint --workspaces && npm run format --workspaces && npm run typecheck --workspaces",
    "deps:check": "syncpack lint && syncpack format --check && knip",
    "deps:fix": "syncpack format && syncpack fix",
    "dev:app": "npm run dev --workspace=my-canister-app",
    "dev:dashboard": "npm run dev --workspace=canister-dashboard-frontend",
    "fix": "npm run lint:fix --workspaces && npm run format:fix --workspaces && npm run typecheck --workspaces",
    "release:publish": "changeset publish && git push && git push --tags",
    "release:version": "changeset version",
    "test:e2e": "./scripts/run-test-e2e.sh",
    "test:setup-ii": "npm run build:setup-ii && playwright test --project=setup-ii"
  },
  "type": "module",
  "workspaces": [
    "my-canister-dapp-js/my-canister-dashboard-js",
    "my-canister-dapp-js/vite-plugin-canister-dapp",
    "my-canister-dapp-js/my-canister-installer",
    "my-canister-dapp-rs/my-canister-dashboard/frontend",
    "my-canister-app",
    "examples/my-hello-world/src/my-hello-world-frontend"
  ]
}
